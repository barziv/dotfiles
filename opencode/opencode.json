{
  "$schema": "https://opencode.ai/config.json",
  "model": "github-copilot/gpt-5.2-codex",
  "autoupdate": true,
  "server": {
    "port": 4096,
  },
  "permission": {
    "read": "allow",
    "grep": "allow",
    "glob": "allow",
    "skill": "allow"
  },
  "plugin": ["opencode-gemini-auth@latest"],
  "mcp": {
    "render": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "mcp-remote",
        "https://mcp.render.com/mcp",
        "--header",
        "Authorization: Bearer ${RENDER_API_KEY}"
      ],
      "enabled": true
    }
  }
}
